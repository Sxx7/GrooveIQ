# GrooveIQ – Environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────

# Random secret key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=CHANGE_ME_generate_a_real_secret_key

# Comma-separated API keys (generate each with the same command above)
# These are what your music apps use in the Authorization: Bearer header
API_KEYS=your-api-key-here,optional-second-key

# Path to your music library on the HOST machine
MUSIC_LIBRARY_PATH=/Users/simon/Documents/music

# ── Optional ──────────────────────────────────────────────────────────────

# Port to expose on the host
GROOVEIQ_PORT=8000

# Environment: production | development
APP_ENV=production

# Set to true ONLY in development (exposes /docs and /redoc)
ENABLE_DOCS=false

# Hosts allowed (comma-separated). Set to your domain in production.
# Example: grooveiq.yourdomain.com,localhost
ALLOWED_HOSTS=*

# CORS origins (comma-separated). Restrict in production.
CORS_ORIGINS=*

# Database — SQLite (default, no config needed) or PostgreSQL
DATABASE_URL=sqlite+aiosqlite:////data/grooveiq.db
# DATABASE_URL=postgresql+asyncpg://grooveiq:password@db/grooveiq

# PostgreSQL password (only needed if using the db service in docker-compose)
# POSTGRES_PASSWORD=change_me

# Audio analysis
ANALYSIS_WORKERS=2           # parallel workers (set to CPU cores - 1)
RESCAN_INTERVAL_HOURS=6      # how often to check for new music files

# Events
EVENT_RETENTION_DAYS=365     # delete raw events older than this

# Resource limits for the container
CPU_LIMIT=2.0
MEM_LIMIT=2G

# Logging
LOG_LEVEL=INFO
LOG_JSON=true                # false for human-readable logs in development

# ── Media server integration ─────────────────────────────────────────────
# Syncs track IDs so events from your media server match scanned tracks.
# Without this, recommendations will be empty (track ID mismatch).

# MEDIA_SERVER_TYPE=plex       # "navidrome" or "plex" (empty = disabled)
# MEDIA_SERVER_URL=http://192.168.1.100:32400
#
# Plex token — find yours with one of these methods:
#   1. Open Plex Web → inspect any media request in browser DevTools →
#      look for "X-Plex-Token" in the URL query string
#   2. curl -s "https://plex.tv/users/sign_in.json" \
#        -X POST -H "X-Plex-Client-Identifier: grooveiq" \
#        -d "user[login]=YOUR_EMAIL&user[password]=YOUR_PASSWORD" \
#        | python3 -m json.tool | grep authToken
#   3. Browse to: http://YOUR_PLEX_IP:32400/myplex/account → find authToken in the XML
# MEDIA_SERVER_TOKEN=your-plex-token
#
# The music root path inside your media server's container (e.g. /data/media/music).
# Check your Plex/Navidrome container's volume mounts to find this.
# MEDIA_SERVER_MUSIC_PATH=/data/media/music
# MEDIA_SERVER_LIBRARY_ID=1    # Plex library section ID (find via: curl -H "X-Plex-Token: TOKEN" http://PLEX:32400/library/sections)
# MEDIA_SERVER_USER=            # Navidrome username (Navidrome only)
# MEDIA_SERVER_PASSWORD=        # Navidrome password (Navidrome only)
