# GrooveIQ – Environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────

# Random secret key (generate with: openssl rand -base64 32)
SECRET_KEY=CHANGE_ME_generate_a_real_secret_key

# Comma-separated API keys — each must be at least 32 characters.
# Generate with:  openssl rand -base64 32
# These are what your music apps use in the Authorization: Bearer header.
# REQUIRED in production (app refuses to start without them).
API_KEYS=

# Explicitly disable authentication (development only).
# Requires API_KEYS to be empty. Ignored when APP_ENV=production.
# DISABLE_AUTH=true

# Path to your music library on the HOST machine
MUSIC_LIBRARY_PATH=/Users/simon/Documents/music

# ── Optional ──────────────────────────────────────────────────────────────

# Port to expose on the host
GROOVEIQ_PORT=8000

# Environment: production | development
APP_ENV=production

# Set to true ONLY in development (exposes /docs and /redoc)
ENABLE_DOCS=false

# Hosts allowed (comma-separated). Must match the Host header your
# reverse proxy sends.  Example: grooveiq.yourdomain.com,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS origins (comma-separated). Leave empty for same-origin only.
# Set to your frontend origin if dashboard is on a different domain.
CORS_ORIGINS=

# Optional: Redis URL for cross-process rate limiting.
# When set, rate limits are shared across all workers/replicas.
# REDIS_URL=redis://localhost:6379/0

# Optional: per-user API key authorization.
# Binds API keys to specific user_id(s) so key A can only access user A's data.
# Format: "key1:alice,bob;key2:charlie"   (keys not listed remain unrestricted)
# API_KEY_USERS=

# Optional: restrict admin operations to specific API keys (comma-separated).
# Admin keys can trigger pipeline runs/resets, library scans/syncs, and view
# aggregate stats across all users.  When empty, all keys have admin access.
# ADMIN_API_KEYS=

# Optional: Fernet key for encrypting media server credentials at rest.
# Generate with:  openssl rand -base64 32
# CREDENTIAL_ENCRYPTION_KEY=

# Database — SQLite (default, no config needed) or PostgreSQL
DATABASE_URL=sqlite+aiosqlite:////data/grooveiq.db
# DATABASE_URL=postgresql+asyncpg://grooveiq:password@db/grooveiq

# PostgreSQL password (only needed if using the db service in docker-compose)
# POSTGRES_PASSWORD=change_me

# Audio analysis
ANALYSIS_WORKERS=2           # parallel workers (set to CPU cores - 1)
RESCAN_INTERVAL_HOURS=6      # how often to check for new music files

# Per-worker thread counts for ONNX Runtime and BLAS libraries.
# ONNX intra_op=2 is the sweet spot for EffNet matmul parallelism.
# OMP/BLAS defaults to 2 (matches Essentia/NumPy threading expectations).
# Reduce to 1 if you see context-switch thrashing with many workers.
# ANALYSIS_ONNX_INTRA_THREADS=2
# ANALYSIS_ONNX_INTER_THREADS=1
# ANALYSIS_OMP_THREADS=2

# GPU acceleration — pick ONE of the two options below:
#
# Option A: NVIDIA GPU (Dockerfile.gpu + nvidia-container-toolkit)
# ANALYSIS_GPU=true
# ANALYSIS_GPU_BATCH_SIZE=64
#
# Option B: Intel iGPU (Dockerfile.igpu + /dev/dri passthrough)
# ANALYSIS_GPU=true
# ANALYSIS_GPU_BACKEND=openvino
# ANALYSIS_GPU_BATCH_SIZE=32
# RENDER_GID=109               # run: stat -c "%g" /dev/dri/renderD128

# Events
EVENT_RETENTION_DAYS=365     # delete raw events older than this

# Resource limits for the container
CPU_LIMIT=2.0
MEM_LIMIT=2G

# Logging
LOG_LEVEL=INFO
LOG_JSON=true                # false for human-readable logs in development

# ── Media server integration ─────────────────────────────────────────────
# Syncs track IDs so events from your media server match scanned tracks.
# Without this, recommendations will be empty (track ID mismatch).

MEDIA_SERVER_TYPE=plex       # "navidrome" or "plex" (empty = disabled)
MEDIA_SERVER_URL=https://plex.local.devii.ch
#
# Plex token — find yours with one of these methods:
#   1. Open Plex Web → inspect any media request in browser DevTools →
#      look for "X-Plex-Token" in the URL query string
#   2. curl -s "https://plex.tv/users/sign_in.json" \
#        -X POST -H "X-Plex-Client-Identifier: grooveiq" \
#        -d "user[login]=YOUR_EMAIL&user[password]=YOUR_PASSWORD" \
#        | python3 -m json.tool | grep authToken
#   3. Browse to: http://YOUR_PLEX_IP:32400/myplex/account → find authToken in the XML
MEDIA_SERVER_TOKEN=CHANGE_ME_GENERATE_A_REAL_TOKEN
#
# The music root path inside your media server's container (e.g. /data/media/music).
# Check your Plex/Navidrome container's volume mounts to find this.
MEDIA_SERVER_MUSIC_PATH=/data/media/music
# MEDIA_SERVER_LIBRARY_ID=1    # Plex library section ID (find via: curl -H "X-Plex-Token: TOKEN" http://PLEX:32400/library/sections)
# MEDIA_SERVER_USER=            # Navidrome username (Navidrome only)
# MEDIA_SERVER_PASSWORD=        # Navidrome password (Navidrome only)

# ── Last.fm ─────────────────────────────────────────────────────────────
# Single API key/secret pair used by both discovery and per-user features.
# Get yours at https://www.last.fm/api/account/create

LASTFM_API_KEY=               # 32-char hex API key (read-only calls)
LASTFM_API_SECRET=            # 32-char hex shared secret (needed for scrobbling)

# ── Music discovery (Last.fm → Lidarr) ─────────────────────────────────
# Discovers new artists via Last.fm similarity and sends them to Lidarr.
# Requires LASTFM_API_KEY + Lidarr credentials to enable.

LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=               # Settings → General → Security in Lidarr UI
# LIDARR_QUALITY_PROFILE_ID=1  # Lidarr quality profile ID
# LIDARR_METADATA_PROFILE_ID=1 # Lidarr metadata profile ID
# LIDARR_ROOT_FOLDER=/music    # Lidarr root folder for new artists
# DISCOVERY_CRON=0 3 * * *     # Cron schedule (default: 3 AM daily UTC)
# DISCOVERY_MAX_REQUESTS_PER_DAY=500  # Daily limit for Lidarr adds
# DISCOVERY_SIMILAR_LIMIT=20   # Similar artists per seed from Last.fm

# ── Charts (Last.fm) ──────────────────────────────────────────────────
# Fetches global/genre/country charts from Last.fm, matches to library,
# optionally auto-adds missing chart artists to Lidarr.
# Requires LASTFM_API_KEY.

CHARTS_ENABLED=false                # Master toggle for periodic chart builds
# CHARTS_INTERVAL_HOURS=24          # How often to rebuild charts
# CHARTS_TOP_LIMIT=100              # Entries per chart (max 200)
# CHARTS_TAGS=rock,electronic,hip-hop  # Genre tags for tag-based charts
# CHARTS_COUNTRIES=germany,united states  # Countries for geo charts
# CHARTS_LIDARR_AUTO_ADD=false      # Auto-add chart artists to Lidarr
# CHARTS_LIDARR_MAX_ADDS=50         # Max artists to add per build

# ── spotdl-api (track downloads via YouTube Music) ────────────────────
# Downloads individual tracks matched via Spotify metadata, audio from
# YouTube Music.  Runs as a separate container (see docker-compose.yml).
# Requires a free Spotify Developer app for API credentials:
#   https://developer.spotify.com/dashboard

SPOTIFY_CLIENT_ID=              # Spotify app Client ID
SPOTIFY_CLIENT_SECRET=          # Spotify app Client Secret
# SPOTDL_API_URL=http://spotdl-api:8181  # Default if spotdl-api service is in compose
# SPOTDL_FORMAT=opus             # Audio format: opus, mp3, m4a, flac, ogg, wav
# SPOTDL_BITRATE=auto            # Bitrate: auto, 128k, 256k, 320k
# SPOTDL_THREADS=4               # Concurrent downloads
# SPOTDL_TEMPLATE={artist}/{album}/{artists} - {title}.{output-ext}
# CHARTS_SPOTIZERR_AUTO_ADD=false        # Auto-download unmatched chart tracks
# CHARTS_SPOTIZERR_MAX_ADDS=50           # Max tracks to download per chart build

# ── Download client toggle ──────────────────────────────────────────────────
# Which download backend to use when multiple are configured.
# Values: "spotdl" (default), "streamrip", "spotizerr"
# DEFAULT_DOWNLOAD_CLIENT=spotdl

# ── streamrip-api (Qobuz/Tidal/Deezer/SoundCloud lossless downloads) ──────
# Downloads from real streaming services in lossless / hi-res quality.
# Requires a paid subscription to at least one service.
# Runs as a separate container (uncomment in docker-compose.yml).

# STREAMRIP_API_URL=http://streamrip-api:8282
# STREAMRIP_QUALITY=3              # 0=128kbps, 1=320kbps, 2=16bit/44.1k, 3=24bit/96k, 4=24bit/192k
# STREAMRIP_CODEC=FLAC             # Output codec
# STREAMRIP_CONNECTIONS=6          # Max concurrent connections
# STREAMRIP_THREADS=4              # Worker threads
# STREAMRIP_DEFAULT_SERVICE=qobuz  # Default service: qobuz, tidal, deezer, soundcloud

# Service credentials (configure at least one):
# Qobuz: email/password login was deprecated. Set QOBUZ_USE_AUTH_TOKEN=true and use
# numeric user_id + auth token (extracted from a logged-in browser session).
# QOBUZ_EMAIL=                     # Email if QOBUZ_USE_AUTH_TOKEN=false; numeric user_id if true
# QOBUZ_PASSWORD=                  # md5(password) if false; auth token if true
# QOBUZ_USE_AUTH_TOKEN=false
# TIDAL_EMAIL=
# TIDAL_PASSWORD=
# TIDAL_EMAIL=
# TIDAL_PASSWORD=
# DEEZER_ARL=                      # Deezer ARL cookie (from browser dev tools)
# SOUNDCLOUD_CLIENT_ID=

# ── slskd / Soulseek (optional — peer-to-peer downloads) ───────────────────
# Requires a running slskd container. Deploy slskd via the arr_stack Ansible
# role (behind Gluetun VPN) and reach it over the shared `apps_default` network.
# Credentials for slskd itself live in Vault (arr-stack/slskd), not here.
# SLSKD_URL=http://gluetun:5030        # slskd shares Gluetun's network namespace
# SLSKD_API_KEY=                         # Same API key you set in Vault for slskd
SLSKD_ENABLED=false
# SLSKD_SEARCH_TIMEOUT=50                # Seconds to wait for Soulseek search results
                                         # (>45s since slskd's internal timeout is 45s)
# SLSKD_PREFER_LOSSLESS=true             # Prefer FLAC over MP3 in result ranking

# ── AcousticBrainz Lookup (optional — audio feature discovery from 29.5M tracks)
# Requires the acousticbrainz-lookup container (uncomment in docker-compose.yml).
# First run downloads ~39 GB data dump (~85 MB with AB_SAMPLE_MODE=true).

AB_LOOKUP_URL=http://acousticbrainz-lookup:8200
AB_LOOKUP_ENABLED=false
# AB_DISCOVERY_LIMIT=50          # Max tracks to discover per pipeline run
# AB_SAMPLE_MODE=false           # Use 100K sample dump instead of full 29.5M

# ── Fill Library (AB taste-match → Lidarr album download) ─────────────
# Queries AcousticBrainz Lookup for tracks matching each user's taste profile,
# groups by album, and sends best-matching albums to Lidarr for FLAC download.
# Requires AB_LOOKUP_URL + LIDARR_URL + LIDARR_API_KEY.

FILL_LIBRARY_ENABLED=false
# FILL_LIBRARY_MAX_ALBUMS=20          # Max albums to queue per run
# FILL_LIBRARY_MAX_DISTANCE=0.15      # Max distance threshold (lower = stricter, 0.15 ≈ 85% match)
# FILL_LIBRARY_CRON=0 4 * * *         # Cron schedule (default: 4 AM daily, after discovery at 3 AM)
# FILL_LIBRARY_QUERY_LIMIT=500        # Max tracks per AB Lookup query per user

# ── Last.fm per-user integration (profile + scrobbling) ────────────────
# Lets users link their Last.fm account for profile enrichment and scrobbling.
# Uses the same LASTFM_API_KEY / LASTFM_API_SECRET above.

# ── Personalized news feed (Reddit-sourced) ──────────────────────────────
# Fetches posts from music subreddits, scores them per-user based on taste profile.
# No API key needed — uses Reddit's public JSON API.

NEWS_ENABLED=false                    # Master toggle for the news feed
# NEWS_INTERVAL_MINUTES=30            # How often to fetch from Reddit
# NEWS_MAX_AGE_HOURS=48               # Discard posts older than this
# NEWS_DEFAULT_SUBREDDITS=Music,hiphopheads,indieheads,electronicmusic,popheads,metal,rnb
# NEWS_MAX_POSTS_PER_SUB=50           # Posts to fetch per subreddit per cycle

LASTFM_ENABLED=false          # Master toggle for per-user Last.fm features
LASTFM_SCROBBLE_ENABLED=false # Forward listening history to Last.fm
# LASTFM_REFRESH_HOURS=6       # How often to pull Last.fm profile data

# Encryption key for storing Last.fm session keys at rest (required for scrobbling).
# Generate with: openssl rand -base64 32
LASTFM_SESSION_ENCRYPTION_KEY=
